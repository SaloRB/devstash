# Neon PostgreSQL — get your connection string from neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Authentication — get your secrets from your auth provider
AUTH_SECRET="your-auth-secret"
AUTH_GITHUB_ID="your-github-id"
AUTH_GITHUB_SECRET="your-github-secret"

# Resend — get your API key from resend.com
RESEND_API_KEY="your-resend-api-key"

# Email verification — set to "true" to require email verification on register
# Leave unset or "false" for local dev (no verified Resend domain required)
EMAIL_VERIFICATION_ENABLED="false"

# App URL — used to build verification links in emails
NEXTAUTH_URL="http://localhost:3000"

# Upstash Redis — get your REST URL and token from upstash.com
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# Stripe — get your keys and price IDs from the Stripe dashboard
STRIPE_SECRET_KEY="api_key_from_stripe_dashboard"
STRIPE_PUBLISHABLE_KEY="publishable_key_from_stripe_dashboard"
STRIPE_WEBHOOK_SECRET="webhook_secret_from_stripe_dashboard"
STRIPE_PRICE_ID_MONTHLY="price_id_monthly_from_stripe_dashboard"
STRIPE_PRICE_ID_YEARLY="price_id_yearly_from_stripe_dashboard"

# OpenAI — get your API key from platform.openai.com
OPENAI_API_KEY="your-openai-api-key"